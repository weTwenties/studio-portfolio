PORT=3001
NODE_ENV=development

# OpenRouter (bilingual translate on publish)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=baidu/cobuddy:free

# SQLite
DATABASE_URL=file:./data/studio-portfolio.db
# Must match web — default is repo root `data/` if unset
PUBLISHED_DATA_DIR=../../data

# CMS Basic auth
CMS_USER=admin
CMS_PASSWORD=change_me

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
