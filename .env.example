NODE_ENV=development
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000/demo-bucket

# OpenRouter (web: pnpm translate | CMS: publish)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=baidu/cobuddy:free

# SQLite
DATABASE_URL=file:./data/studio-portfolio.db

# Shared snapshot JSON for CMS publish + web (members.json, projects.json, site.json)
PUBLISHED_DATA_DIR=./data

# CMS Basic auth
CMS_USER=admin
CMS_PASSWORD=change_me

# Cloudflare R2 (optional — image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
